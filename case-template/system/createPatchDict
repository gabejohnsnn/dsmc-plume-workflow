FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      createPatchDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

pointSync false;

patches
(
    {
        name front;
        patchInfo
        {
            type wedge;
        }
        constructFrom set;
        set frontFaces;
    }
    {
        name back;
        patchInfo
        {
            type wedge;
        }
        constructFrom set;
        set backFaces;
    }
);

