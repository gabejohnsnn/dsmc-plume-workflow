FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      dsmcInitialiseDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

configurations
(
    configuration
    {
        type            dsmcMeshFill;
        typeIds         (EqGas);
        numberDensities
        {
            EqGas       1e18;
        };
        translationalTemperature    300;
        rotationalTemperature       0;
        vibrationalTemperature      0;
        electronicTemperature       0;
        velocity                    (0 0 0);
    }
);

